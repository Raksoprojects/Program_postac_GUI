{
  "name": "wfrp4e-karta-postaci",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interaktywna karta postaci WFRP 4ed - aplikacja webowa (PWA)",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "build:nocheck": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:test": "tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.19.43",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
